# SentinelWeb environment example
# Copy to .env for local development. Do not commit real secrets.

# Server
PORT=8766
HEADLESS=true
ALLOWED_ORIGINS=https://sentinelprime.org,https://www.sentinelprime.org,http://localhost:5173,http://127.0.0.1:5173

# Tiny AI helper. Required for inventory request parsing and result summaries.
AI_HELPER_ENABLED=true
AI_HELPER_REQUIRED=true
AI_HELPER_PROVIDER=ollama
AI_HELPER_MODEL=llama3.2:1b
AI_HELPER_HOST=http://127.0.0.1:11434
AI_HELPER_TIMEOUT_S=10

# Legacy/larger Ollama flows stay disabled on Railway. Do not use 7B/14B models there.
OLLAMA_ENABLED=false
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:1b

# Private inventory beta
# Comma-separated allowlist. Keep this to 15 users or fewer.
SENTINEL_BETA_USERS=

# Optional bearer token for internal service checks. Cloudflare Access email
# plus SENTINEL_BETA_USERS should remain the normal production auth path.
SENTINEL_AUTH_TOKEN=

# Optional local/API testing bearer tokens, comma-separated email:token pairs.
SENTINEL_BETA_API_KEYS=

# Inventory cache defaults to 12 minutes. Use 600-900 seconds for 10-15 minutes.
SENTINEL_INVENTORY_CACHE_TTL_S=720
